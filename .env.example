# URL publique du site (SEO / Open Graph). Ex. https://ton-domaine.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optionnel : webhook pour la liste d’attente (landing). POST JSON { email, source }
WAITLIST_WEBHOOK_URL=

# Supabase - À configurer avec tes vraies valeurs
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OAuth Gmail
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OAuth Outlook / Microsoft Graph
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
